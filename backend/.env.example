# Django
SECRET_KEY=change-me-to-a-long-random-secret-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS - comma separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (Resend — https://resend.com)
# Gmail SMTP is NOT used in production: Render's free tier blocks/hangs on
# outbound SMTP (port 587), causing contact-form/Compose emails to time out
# with no response. Resend sends over HTTPS instead, which works fine on
# Render. Sign up at resend.com, verify a sending domain (or use their
# shared test domain while developing), and create an API key.
RESEND_API_KEY=re_your_api_key_here
DEFAULT_FROM_EMAIL=you@your-verified-domain.com
CONTACT_RECEIVER_EMAIL=you@your-verified-domain.com

# Frontend base URL, used to build links (e.g. password reset emails)
FRONTEND_URL=http://localhost:5173
