# Django
SECRET_KEY=change-me-to-a-long-random-secret-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS - comma separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email (Gmail SMTP)
EMAIL_HOST_USER=your-gmail-address@gmail.com
# IMPORTANT: This must be a Gmail App Password (generated under Google Account
# > Security > 2-Step Verification > App Passwords), NOT your regular Gmail
# account password. Regular passwords will not work with SMTP auth once
# 2-Step Verification is enabled (and Google requires an app password anyway).
EMAIL_HOST_PASSWORD=your-16-character-app-password
DEFAULT_FROM_EMAIL=your-gmail-address@gmail.com
CONTACT_RECEIVER_EMAIL=your-gmail-address@gmail.com

# Frontend base URL, used to build links (e.g. password reset emails)
FRONTEND_URL=http://localhost:5173
